#include <iostream>
#include <vector>
 
using namespace std;
 
void solve() {
    int n, k;
    cin >> n >> k;
    
    bool found = false;
    for (int i = 0; i < n; i++) {
        int element;
        cin >> element;
        if (element == k) {
            found = true;
        }
    }
    
    if (found) {
        cout << "YES
";
    } else {
        cout << "NO
";
    }
}
 
int main() {
    // Optimizes standard input/output streams for speed
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    
    int t;
    cin >> t;
    while (t--) {
        solve();
    }
    
    return 0;
}